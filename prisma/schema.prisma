generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  subscribedAt   DateTime?
  unsubscribedAt DateTime?
  archivedAt     DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?
  source         String?

  lists         ContactList[]
  campaignSends CampaignSend[]
}

model List {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contacts  ContactList[]
  campaigns Campaign[]
}

model ContactList {
  id        String   @id @default(cuid())
  contactId String
  listId    String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  list    List    @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([contactId, listId])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  html      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  subject     String
  body        String
  html        String?
  status      String    @default("draft")
  listId      String
  templateId  String?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  list     List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  template Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sends    CampaignSend[]
}

model LoginToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model CampaignSend {
  id         String    @id @default(cuid())
  campaignId String
  contactId  String?
  email      String
  status     String
  error      String?
  sentAt     DateTime  @default(now())
  openedAt   DateTime?

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  clicks   CampaignClick[]
}

model CampaignClick {
  id        String   @id @default(cuid())
  sendId    String
  url       String
  clickedAt DateTime @default(now())

  send CampaignSend @relation(fields: [sendId], references: [id], onDelete: Cascade)
}

// ─── IBSA / Xylo Convention Supply ───────────────────────────────────────────

model IbsaProduct {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  variant   String?
  category  String   // safety_ppe | janitorial | chemicals | special | firstaid
  type      String   // CS | FA
  unitCost  Float
  xyloCost  Float?
  inStock   Int      @default(0)
  git       Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems IbsaOrderItem[]
}

model IbsaConvention {
  id             String    @id @default(cuid())
  name           String
  venue          String?
  conventionDate DateTime
  deliveryDate   DateTime?
  status         String    @default("pending") // pending | ordered | complete
  shippingCost   Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orderItems IbsaOrderItem[]
}

model IbsaOrderItem {
  id           String   @id @default(cuid())
  conventionId String
  productId    String
  qty          Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  convention IbsaConvention @relation(fields: [conventionId], references: [id], onDelete: Cascade)
  product    IbsaProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([conventionId, productId])
}
