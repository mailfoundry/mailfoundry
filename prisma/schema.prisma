generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  subscribedAt   DateTime?
  unsubscribedAt DateTime?
  archivedAt     DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?
  source         String?

  lists         ContactList[]
  campaignSends CampaignSend[]
}

model List {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contacts  ContactList[]
  campaigns Campaign[]
}

model ContactList {
  id        String   @id @default(cuid())
  contactId String
  listId    String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  list    List    @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([contactId, listId])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  html      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  subject     String
  body        String
  html        String?
  status      String    @default("draft")
  listId      String
  templateId  String?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  list     List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  template Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sends    CampaignSend[]
}

model LoginToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model CampaignSend {
  id         String    @id @default(cuid())
  campaignId String
  contactId  String?
  email      String
  status     String
  error      String?
  sentAt     DateTime  @default(now())
  openedAt   DateTime?

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  clicks   CampaignClick[]
}

model CampaignClick {
  id        String   @id @default(cuid())
  sendId    String
  url       String
  clickedAt DateTime @default(now())

  send CampaignSend @relation(fields: [sendId], references: [id], onDelete: Cascade)
}

// ─── IBSA / Xylo Convention Supply ───────────────────────────────────────────

model IbsaUser {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model IbsaProduct {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  variant   String?
  category  String   // safety_ppe | janitorial | chemicals | special | firstaid
  type      String   // CS | FA
  unitCost  Float
  xyloCost  Float?
  inStock   Int      @default(0)
  git       Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems      IbsaOrderItem[]
  rsProducts      RsProduct[]
  groupOrderLines IbsaGroupOrderLine[]
}

/// One row per (RS product code + Xylo product) mapping.
/// A single Xylo product may require multiple RS lines (e.g. brush head + handle sold separately).
model RsProduct {
  id            String       @id @default(cuid())
  supplier      String       @default("Robert Scott") // Supplier name, e.g. "Robert Scott"
  rsCode        String?      // Supplier catalog code — null until catalog data is entered
  rsVariant     String?      // Colour / variant as shown by supplier, e.g. "BLUE", "RED"
  rsDescription String?      // Supplier product description — null until catalog data is entered
  cartonSize    Int?         // Units per carton — null until catalog data is entered
  cartonPrice   Float?       // Price per carton (ex VAT) in GBP — null until catalog data is entered
  ibsaProductId String?      // FK to IbsaProduct.id — null if not yet linked
  ibsaProduct   IbsaProduct? @relation(fields: [ibsaProductId], references: [id], onDelete: SetNull)
  notes         String?      // Free-text notes (e.g. discontinued, substitution)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([rsCode])
  @@index([ibsaProductId])
}

model IbsaConvention {
  id              String    @id @default(cuid())
  name            String
  venue           String?
  conventionDate  DateTime

  // CS (Cleaning Supplies) logistics
  status          String    @default("pending") // pending | ordered | complete
  collectionDate  DateTime?
  deliveryDate    DateTime?
  deliveryAddress String?
  shippingCost    Float     @default(0)
  paymentDueDate  DateTime?
  paidAt          DateTime?

  // FA (First Aid) logistics
  faStatus          String    @default("pending") // pending | ordered | complete
  faCollectionDate  DateTime?
  faDeliveryDate    DateTime?
  faDeliveryAddress String?
  faShippingCost    Float     @default(0)
  faPaymentDueDate  DateTime?
  faPaidAt          DateTime?

  // Shared contact
  contactName     String?
  contactEmail    String?
  contactMobile   String?
  notes           String?   // free-text notes, e.g. invoice discrepancy explanations
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orderItems IbsaOrderItem[]
}

model IbsaOrderItem {
  id           String   @id @default(cuid())
  conventionId String
  productId    String
  dept         String   @default("CS") // CS | FA — which invoice this line came from
  qty          Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  convention IbsaConvention @relation(fields: [conventionId], references: [id], onDelete: Cascade)
  product    IbsaProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([conventionId, productId, dept])
}

/// A saved snapshot of a supplier purchase order.
model IbsaPurchaseOrder {
  id         String    @id @default(cuid())
  poNumber   String
  supplier   String
  /// ordered | partial | received | cancelled
  status     String    @default("ordered")
  orderedAt  DateTime  @default(now())
  receivedAt DateTime?
  totalExVat Float     @default(0)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lines IbsaPurchaseOrderLine[]
}

/// One line within a purchase order.
model IbsaPurchaseOrderLine {
  id              String            @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   IbsaPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  rsCode          String?
  description     String
  variant         String?
  cartonSize      Int?
  cartonsOrdered  Int
  cartonsReceived Int               @default(0)
  pricePerCarton  Float?
  totalCost       Float?
  /// JSON: [{ibsaProductId, name, units}]
  productBreakdown String           @default("[]")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([purchaseOrderId])
}

/// Single-use token emailed to convention overseers so they can fill in their product order.
model ConventionOrderToken {
  id           String    @id @default(cuid())
  token        String    @unique
  email        String
  conventionId String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([conventionId])
}

/// An order placed by a congregation, circuit assembly, or regional group.
model IbsaGroupOrder {
  id            String    @id @default(cuid())
  /// congregation | circuit | regional
  groupType     String
  groupName     String
  contactName   String
  contactEmail  String
  contactMobile String?
  /// submitted | processing | complete | cancelled
  status        String    @default("submitted")
  notes         String?
  submittedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lines IbsaGroupOrderLine[]

  @@index([status])
}

/// One line within a group order.
model IbsaGroupOrderLine {
  id         String         @id @default(cuid())
  orderId    String
  order      IbsaGroupOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    IbsaProduct    @relation(fields: [productId], references: [id])
  /// CS | FA
  dept       String
  qty        Int

  @@unique([orderId, productId, dept])
  @@index([orderId])
}

/// Supplier contact book. name matches RsProduct.supplier for cascade renames.
model IbsaSupplier {
  id          String   @id @default(cuid())
  name        String   @unique // Must match RsProduct.supplier — rename cascades via server action
  contactName String?
  email       String?
  mobile      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
