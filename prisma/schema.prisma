generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  lastName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  subscribedAt   DateTime?
  unsubscribedAt DateTime?
  archivedAt     DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?
  source         String?

  lists         ContactList[]
  campaignSends CampaignSend[]
}

model List {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contacts  ContactList[]
  campaigns Campaign[]
}

model ContactList {
  id        String   @id @default(cuid())
  contactId String
  listId    String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  list    List    @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([contactId, listId])
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  html      String?
  status    String   @default("draft")
  listId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list  List           @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends CampaignSend[]
}

model LoginToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model CampaignSend {
  id         String    @id @default(cuid())
  campaignId String
  contactId  String?
  email      String
  status     String
  error      String?
  sentAt     DateTime  @default(now())
  openedAt   DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}
